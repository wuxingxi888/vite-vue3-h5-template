{
  "name": "vite-vue3-h5-template",
  "version": "1.0.0",
  "author": {
    "name": "wuXingXi",
    "email": "wuxingxi888@gmail.com",
    "url": "https://github.com/wuxingxi888"
  },
  "bugs": {
    "url": "https://github.com/wuxingxi888/vite-vue3-h5-template/issues"
  },
  "homepage": "https://github.com/wuxingxi888/vite-vue3-h5-template#readme",
  "keywords": [
    "vue3",
    "typescript",
    "template",
    "vite",
    "pinia",
    "vant"
  ],
  "scripts": {
    "dev": "vite --mode development",
    "prod": "vite --mode production",
    "build:test": "vue-tsc --noEmit && vite build --mode test && esno ./src/utils/build.ts",
    "build:prod": "vue-tsc --noEmit && vite build --mode production && esno ./src/utils/build.ts",
    "build": "vue-tsc --noEmit && vite build",
    "clean:cache": "rm -rf node_modules && rm -rf .eslintcache && pnpm install",
    "preview": "pnpm run build:prod && vite preview --port 5050",
    "preview:dist": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:lint-staged": "lint-staged",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@vueuse/core": "^11.1.0",
    "axios": "^1.7.7",
    "crypto-js": "^4.1.1",
    "disable-devtool": "^0.3.7",
    "json-bigint": "^1.0.0",
    "mitt": "^3.0.0",
    "pinia": "^2.0.9",
    "pinia-plugin-persistedstate": "^4.1.1",
    "vant": "^4.0.10",
    "vue": "^3.2.26",
    "vue-router": "^4.0.12"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.1.0",
    "@types/crypto-js": "^4.1.1",
    "@types/json-bigint": "^1.0.1",
    "@types/node": "^22.7.8",
    "@vitejs/plugin-legacy": "^5.4.2",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitejs/plugin-vue-jsx": "^4.0.1",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.1.2",
    "autoprefixer": "^10.4.2",
    "consola": "^3.2.3",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.29.1",
    "esno": "^4.8.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.32",
    "postcss-mobile-forever": "^4.2.2",
    "prettier": "^3.3.3",
    "rollup-plugin-external-globals": "^0.12.0",
    "rollup-plugin-visualizer": "^5.9.0",
    "sass": "~1.32.6",
    "terser": "^5.36.0",
    "typescript": "~5.6.3",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.9",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-style-import": "^2.0.0",
    "vue-global-api": "^0.4.1",
    "vue-tsc": "^2.1.6"
  },
  "peerDependencies": {
    "postcss": "^8.1.0"
  },
  "resolutions": {
    "bin-wrapper": "npm:bin-wrapper-china"
  }
}